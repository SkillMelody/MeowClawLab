  "component_variants": {"cover": "consulting-header", "judgment_evidence": "cards.default", "metric": "cards.metric", "table": "table_tokens.default", "chart": "chart_tokens"},
  "allowed_effects": ["subtle_divider", "single_accent_rule", "bounded_material_layer"],
  "forbidden_drift": ["bright saturated gradients", "full-slide raster for ordinary tables", "connector web without main path"],
