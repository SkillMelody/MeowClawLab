{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://meowclaw.local/article-html-to-ppt/delivery-manifest.schema.json",
  "title": "article-html-to-ppt Delivery Manifest v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "deck_id",
    "build_id",
    "profile",
    "status",
    "generated_at",
    "files",
    "builder",
    "renderer",
    "metrics",
    "fallbacks",
    "known_limitations",
    "privacy"
  ],
  "properties": {
    "schema_version": {"const": "1.0"},
    "deck_id": {"type": "string", "minLength": 1},
    "build_id": {"type": "string", "minLength": 1},
    "profile": {"enum": ["fast", "standard", "premium"]},
    "status": {"enum": ["planned", "created", "rendered", "read_back", "verified", "final", "failed"]},
    "generated_at": {"type": "string", "minLength": 1},
    "files": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["role", "path", "required", "hash"],
        "properties": {
          "role": {
            "enum": [
              "pptx",
              "preview_pdf",
              "verification_report",
              "delivery_manifest",
              "assets",
              "source_package"
            ]
          },
          "path": {
            "type": "string",
            "minLength": 1,
            "not": {"pattern": "^(/|[A-Za-z]:\\\\)"}
          },
          "required": {"type": "boolean"},
          "hash": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"}
        }
      }
    },
    "builder": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "version"],
      "properties": {
        "name": {"type": "string"},
        "version": {"type": "string"}
      }
    },
    "renderer": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "version"],
      "properties": {
        "name": {"type": ["string", "null"]},
        "version": {"type": ["string", "null"]}
      }
    },
    "metrics": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "editable_core_ratio": {"type": ["number", "null"], "minimum": 0, "maximum": 1},
        "native_text_ratio": {"type": ["number", "null"], "minimum": 0, "maximum": 1},
        "rasterized_area_ratio": {"type": ["number", "null"], "minimum": 0, "maximum": 1},
        "whole_slide_raster_count": {"type": ["integer", "null"], "minimum": 0},
        "qa_error_count": {"type": ["integer", "null"], "minimum": 0},
        "qa_warning_count": {"type": ["integer", "null"], "minimum": 0},
        "rubric_score": {"type": ["number", "null"], "minimum": 0}
      }
    },
    "fallbacks": {
      "type": "array",
      "items": {"type": "object"}
    },
    "known_limitations": {
      "type": "array",
      "items": {"type": "string"}
    },
    "privacy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["contains_private_assets", "contains_external_links", "issues"],
      "properties": {
        "contains_private_assets": {"type": "boolean"},
        "contains_external_links": {"type": "boolean"},
        "issues": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["code", "file"],
            "properties": {
              "code": {
                "enum": [
                  "DELIVERY_PRIVATE_PATH_LEAK",
                  "DELIVERY_SECRET_LEAK",
                  "DELIVERY_TEMP_FILE_INCLUDED",
                  "DELIVERY_UNDECLARED_PRIVATE_ASSET"
                ]
              },
              "file": {"type": "string"}
            }
          }
        }
      }
    },
    "resume": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "resume_from": {"type": ["string", "null"]},
        "last_successful_stage": {"type": ["string", "null"]},
        "failed_stage": {"type": ["string", "null"]},
        "checkpoints": {"type": ["string", "null"]}
      }
    },
    "package_zip": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "hash"],
      "properties": {
        "path": {"type": "string", "minLength": 1},
        "hash": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"}
      }
    }
  }
}
