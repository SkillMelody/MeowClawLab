{
  "schema_version": "1.0",
  "pack_id": "technical-blueprint",
  "display_name": "Technical Blueprint Production Pack",
  "description": "Light technical whitepaper system for implementation judgments, evidence, architecture, process, comparison, and handoff.",
  "style_contract": {
    "style_id": "technical-blueprint",
    "schema_version": "2.0",
    "ref": "../../tests/fixtures/styles/technical-blueprint.json"
  },
  "compatible_expression_modes": [
    "textual_argument",
    "structured_cards",
    "table_matrix",
    "data_visual",
    "relationship_visual"
  ],
  "archetypes": [
    {
      "role": "cover",
      "page_archetype": "executive-cover",
      "intent": "Name the system, implementation thesis, and operating context without a decorative blueprint mural.",
      "allowed_expression_modes": [
        "textual_argument"
      ],
      "component_routes": [
        {
          "component_type": "material_background",
          "expression_mode": "textual_argument",
          "preferred_route": "background_image",
          "allowed_routes": [
            "background_image",
            "generated_image",
            "hybrid_overlay"
          ],
          "editability": "raster_allowed"
        }
      ],
      "editable_core": [
        "title",
        "subtitle",
        "system_context",
        "version"
      ]
    },
    {
      "role": "judgment",
      "page_archetype": "claim-evidence",
      "intent": "State the engineering judgment first and preserve assumptions, constraints, and proof.",
      "allowed_expression_modes": [
        "textual_argument",
        "structured_cards"
      ],
      "component_routes": [
        {
          "component_type": "body_argument",
          "expression_mode": "textual_argument",
          "preferred_route": "native_ppt",
          "allowed_routes": [
            "native_ppt"
          ],
          "editability": "native_required"
        },
        {
          "component_type": "evidence_block",
          "expression_mode": "structured_cards",
          "preferred_route": "native_ppt",
          "allowed_routes": [
            "native_ppt"
          ],
          "editability": "native_required"
        }
      ],
      "editable_core": [
        "judgment_title",
        "argument",
        "constraints",
        "evidence",
        "source_note"
      ]
    },
    {
      "role": "evidence_data",
      "page_archetype": "observability-dashboard",
      "intent": "Show operational health or implementation evidence with native metrics and chart data.",
      "allowed_expression_modes": [
        "data_visual"
      ],
      "component_routes": [
        {
          "component_type": "kpi_dashboard",
          "expression_mode": "data_visual",
          "preferred_route": "native_ppt",
          "allowed_routes": [
            "native_ppt",
            "native_chart"
          ],
          "editability": "native_required"
        }
      ],
      "editable_core": [
        "judgment_title",
        "numbers",
        "labels",
        "chart_data",
        "thresholds",
        "source_note"
      ]
    },
    {
      "role": "process_relationship",
      "page_archetype": "system-architecture",
      "intent": "Expose layers, ownership, trust boundaries, and the dominant data or control path.",
      "allowed_expression_modes": [
        "relationship_visual"
      ],
      "component_routes": [
        {
          "component_type": "layered_architecture",
          "expression_mode": "relationship_visual",
          "preferred_route": "native_diagram",
          "allowed_routes": [
            "native_diagram",
            "hybrid_overlay",
            "svg_component"
          ],
          "editability": "native_preferred"
        },
        {
          "component_type": "process_lane",
          "expression_mode": "relationship_visual",
          "preferred_route": "native_diagram",
          "allowed_routes": [
            "native_diagram",
            "hybrid_overlay",
            "svg_component"
          ],
          "editability": "native_preferred"
        }
      ],
      "editable_core": [
        "judgment_title",
        "layer_labels",
        "node_labels",
        "boundary_labels",
        "legend",
        "main_path_annotations"
      ]
    },
    {
      "role": "comparison_implementation",
      "page_archetype": "implementation-roadmap",
      "intent": "Make phases, milestones, dependencies, and implementation decisions executable.",
      "allowed_expression_modes": [
        "relationship_visual",
        "table_matrix"
      ],
      "component_routes": [
        {
          "component_type": "timeline",
          "expression_mode": "relationship_visual",
          "preferred_route": "native_diagram",
          "allowed_routes": [
            "native_diagram",
            "hybrid_overlay",
            "svg_component"
          ],
          "editability": "native_preferred"
        },
        {
          "component_type": "decision_matrix",
          "expression_mode": "table_matrix",
          "preferred_route": "native_table",
          "allowed_routes": [
            "native_table"
          ],
          "editability": "native_required"
        }
      ],
      "editable_core": [
        "judgment_title",
        "phases",
        "milestones",
        "dependencies",
        "criteria",
        "scores",
        "recommendation"
      ]
    },
    {
      "role": "closing",
      "page_archetype": "closing-standard",
      "intent": "End with implementation ownership, timing, unresolved risk, and the next decision.",
      "allowed_expression_modes": [
        "structured_cards"
      ],
      "component_routes": [
        {
          "component_type": "summary_action_card",
          "expression_mode": "structured_cards",
          "preferred_route": "native_ppt",
          "allowed_routes": [
            "native_ppt"
          ],
          "editability": "native_required"
        }
      ],
      "editable_core": [
        "conclusion",
        "action",
        "owner",
        "timing",
        "open_risk"
      ]
    }
  ],
  "editable_core_policy": {
    "required_native_objects": [
      "judgment_title",
      "body_argument",
      "evidence_block",
      "kpi_dashboard",
      "decision_matrix",
      "summary_action_card"
    ],
    "required_editable_elements": [
      "titles",
      "body_text",
      "metrics",
      "chart_data",
      "node_labels",
      "boundary_labels",
      "legends",
      "actions"
    ],
    "bounded_visual_requires_native_overlay": true,
    "whole_slide_raster_forbidden": true
  },
  "forbidden_patterns": [
    "screenshot-only or dead master decks",
    "whole-slide rasterization",
    "decorative connector webs",
    "raw blueprint or wireframe aesthetics",
    "hidden ownership or trust boundaries",
    "rasterized ordinary tables, metrics, or simple diagrams",
    "invented implementation evidence",
    "undeclared delivery-route changes"
  ],
  "truthful_constraints": {
    "renderer_evidence_required_for_final": true,
    "disclose_route_deviations": true,
    "disclose_raster_or_generated_components": true,
    "notes": [
      "The pack defines reusable contract and routing policy; it is not evidence that a deck was rendered or verified.",
      "Premium final status still requires real renderer evidence, readback, zero QA errors, and the required rubric pass."
    ]
  }
}
